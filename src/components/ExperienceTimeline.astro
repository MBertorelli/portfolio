---
import { experience } from '../data/profile';

const tracks = [
  { id: 'industry', label: '/industry', note: 'Full-time roles' },
  { id: 'freelance', label: '/freelance', note: 'Independent client work' },
].map((t) => ({ ...t, jobs: experience.filter((job) => job.track === t.id) }));
---

<div class="tracks">
  {
    tracks.map((track) => (
      <div class="track">
        <div class="track-head">
          <h3 class="mono">{track.label}</h3>
          <p>{track.note}</p>
        </div>
        <ol class="timeline">
          {track.jobs.map((job) => (
            <li>
              <div class="head">
                <h4>{job.role}</h4>
                <span class="dates mono">{job.dates}</span>
              </div>
              <p class="org">{job.org}</p>
              <p class="summary">{job.summary}</p>
              {job.stack && (
                <p class="stack">
                  {job.stack.map((s) => (
                    <span class="tag">{s}</span>
                  ))}
                </p>
              )}
            </li>
          ))}
        </ol>
      </div>
    ))
  }
</div>

<style>
  .tracks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }
  @media (max-width: 760px) {
    .tracks {
      grid-template-columns: 1fr;
    }
  }
  .track-head {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .track-head h3 {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--accent-deep);
  }
  .track-head p {
    font-size: 0.85rem;
    color: var(--ink-faint);
  }
  .timeline {
    list-style: none;
    padding: 0;
    /* the pipeline rail — brand signature */
    border-left: 2px solid var(--border);
    margin-left: 0.3rem;
  }
  li {
    position: relative;
    padding: 0 0 2.2rem 1.4rem;
  }
  li:last-child {
    padding-bottom: 0.5rem;
  }
  /* stage node on the rail */
  li::before {
    content: '';
    position: absolute;
    left: calc(-0.35rem - 1px);
    top: 0.45rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
  }
  li:first-child::before {
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-wash);
  }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  h4 {
    font-size: 1rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    font-weight: 650;
  }
  .dates {
    font-size: 0.75rem;
    color: var(--ink-faint);
  }
  .org {
    color: var(--accent-deep);
    font-weight: 550;
    font-size: 0.92rem;
    margin: 0.15rem 0 0.5rem;
  }
  .summary {
    color: var(--ink-soft);
    font-size: 0.93rem;
  }
  .stack {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.7rem;
  }
</style>
