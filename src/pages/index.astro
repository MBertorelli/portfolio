---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import Contact from '../components/Contact.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

// Tabbed display: freelance work first (the goal), then industry, then personal.
const groups = [
  {
    category: 'freelance',
    label: 'freelance',
    note: 'Independent client work — delivered end to end.',
    empty: 'Freelance case studies are coming.',
  },
  {
    category: 'industry',
    label: 'industry',
    note: 'Case studies from full-time roles, anonymized where needed.',
    empty: 'Industry case studies are coming.',
  },
  {
    category: 'personal',
    label: 'personal',
    note: 'Pet projects — built to learn, shared to show how I think.',
    empty: 'Pet projects are on their way — meanwhile, /freelance and /industry cover the shipped work.',
  },
].map((g) => ({ ...g, projects: projects.filter((p) => p.data.category === g.category) }));
---

<Base>
  <main>
    <Hero />

    <Section id="experience" eyebrow="stage 01 / experience" title="Where I've built">
      <ExperienceTimeline />
    </Section>

    <Section id="projects" eyebrow="stage 02 / case studies" title="Selected work">
      <div class="tabs mono" role="tablist" aria-label="Case study categories">
        {
          groups.map((group, i) => (
            <button
              class="tab"
              role="tab"
              id={`tab-${group.category}`}
              aria-controls={`panel-${group.category}`}
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              /{group.label}
            </button>
          ))
        }
      </div>
      {
        groups.map((group, i) => (
          <div
            class="group"
            role="tabpanel"
            id={`panel-${group.category}`}
            aria-labelledby={`tab-${group.category}`}
            hidden={i !== 0}
          >
            <p class="group-note">{group.note}</p>
            {group.projects.length === 0 ? (
              <p class="group-empty">{group.empty}</p>
            ) : (
              <div class="cards">
                {group.projects.map((project) => (
                  <ProjectCard {project} />
                ))}
              </div>
            )}
          </div>
        ))
      }
    </Section>

    <script>
      const tabs = [...document.querySelectorAll<HTMLButtonElement>('.tab[role="tab"]')];
      for (const tab of tabs) {
        tab.addEventListener('click', () => {
          for (const t of tabs) {
            const selected = t === tab;
            t.setAttribute('aria-selected', String(selected));
            const panel = document.getElementById(t.getAttribute('aria-controls')!);
            if (panel) panel.hidden = !selected;
          }
        });
      }
    </script>

    <Section id="skills" eyebrow="stage 03 / stack" title="Tools I reach for">
      <SkillsGrid />
    </Section>

    <Section id="contact" eyebrow="stage 04 / deploy" title="Let's work together">
      <Contact />
    </Section>
  </main>
</Base>

<style>
  .tabs {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.4rem;
  }
  .tab {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    padding: 0.45rem 0.8rem;
    cursor: pointer;
  }
  .tab:hover {
    color: var(--accent-deep);
  }
  .tab[aria-selected='true'] {
    color: var(--accent-deep);
    border-bottom-color: var(--accent);
  }
  .group-note {
    font-size: 0.85rem;
    color: var(--ink-faint);
    margin-bottom: 1rem;
  }
  .group-empty {
    color: var(--ink-soft);
    font-size: 0.95rem;
    max-width: 52ch;
    padding-block: 0.5rem 1rem;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(19rem, 100%), 1fr));
    gap: 1.2rem;
  }
</style>
